{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
    <div style="display: flex; flex-direction: column; justify-content: left; align-items: left; height: 80vh;">
        
        <table class="table table-bordered" style="max-width: 500px; background: #fff; margin-top: 20px;">
            <tr>
                <th style="width: 150px;">Prénom</th>
                <td>{{ user.firstname }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ user.lastname }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Rôles</th>
                <td>
                    {% for role in user.roles %}
                        <span style="display:inline-block; background:#007bff; color:#fff; border-radius:12px; padding:2px 10px; margin:2px; font-size:0.95em;">{{ role }}</span>
                    {% else %}
                        <span class="text-muted">Aucun rôle</span>
                    {% endfor %}
                </td>
            </tr>
        </table>

        <a href="{{ editUrl }}" class="btn btn-primary mb-4" style="align-self: flex-start; margin-bottom: 20px;">Modifier mes infos</a>
    </div>
{% endblock %}
